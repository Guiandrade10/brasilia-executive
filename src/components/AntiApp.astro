---
import SkylineDivider from './SkylineDivider.astro';

export interface Props {
  title: string;
  body: string;
}
const { title, body } = Astro.props;
---

<section class="anti">
  <div class="wrap">
    <SkylineDivider variant="inline" color="brass" />
    <h2>{title}</h2>
    <p>{body}</p>
  </div>
</section>

<style>
  .anti {
    background: var(--ink);
    color: var(--paper);
    padding: 5rem 1.25rem;
  }
  .wrap {
    max-width: 60rem;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }
  h2 {
    color: var(--paper);
    max-width: 22ch;
  }
  p {
    color: var(--paper);
    opacity: 0.85;
    max-width: 62ch;
    font-size: 1.05rem;
    line-height: 1.7;
  }
</style>

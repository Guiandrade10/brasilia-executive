---
import type { Lang } from '../i18n/ui';
import { t, routes } from '../i18n/ui';
import WhatsAppCTA from './WhatsAppCTA.astro';
import LangSwitcher from './LangSwitcher.astro';

export interface Props {
  lang: Lang;
  page: keyof typeof routes.pt;
}

const { lang, page } = Astro.props;
const r = routes[lang];
---

<header class="site-header">
  <a href="#main" class="skip-link">{t(lang, 'skip.content')}</a>
  <div class="wrap">
    <a href={r.home} class="brand" aria-label="Brasília Executive">
      <span class="brand-name">BRASÍLIA EXECUTIVE</span>
    </a>
    <nav class="nav" aria-label={t(lang, 'nav.services')}>
      <a href={r.transfer}>{t(lang, 'nav.transfer')}</a>
      <a href={r.daily}>{t(lang, 'nav.daily')}</a>
      <a href={r.wedding}>{t(lang, 'nav.wedding')}</a>
      <a href={r.escort}>{t(lang, 'nav.escort')}</a>
    </nav>
    <div class="actions">
      <LangSwitcher current={lang} page={page} />
      <WhatsAppCTA
        context="global"
        lang={lang}
        label={t(lang, 'nav.whatsapp')}
        variant="ghost-dark"
        analytics={`whatsapp_header_${lang}`}
      />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--ink);
    color: var(--paper);
    border-bottom: 1px solid var(--line-dark);
  }
  .wrap {
    max-width: 76rem;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.14em;
    color: var(--paper);
  }
  .nav {
    display: none;
    gap: 1.5rem;
    margin-left: auto;
  }
  .nav a {
    color: var(--paper);
    font-size: 0.9rem;
    opacity: 0.85;
    transition: opacity 150ms ease, color 150ms ease;
  }
  .nav a:hover { opacity: 1; color: var(--brass); }
  .actions {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }
  @media (min-width: 900px) {
    .nav { display: inline-flex; }
    .actions { margin-left: 0; }
  }
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
  }
  .skip-link:focus {
    left: 1rem;
    top: 1rem;
    background: var(--paper);
    color: var(--ink);
    padding: 0.5rem 0.75rem;
    z-index: 100;
  }
</style>

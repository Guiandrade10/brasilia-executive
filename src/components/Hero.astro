---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import WhatsAppCTA from './WhatsAppCTA.astro';
import SkylineDivider from './SkylineDivider.astro';

export interface Props {
  lang: Lang;
  eyebrow: string;
  headline: string;
  sub: string;
  bgImage?: string;
  bgAlt?: string;
}
const { lang, eyebrow, headline, sub, bgImage, bgAlt } = Astro.props;
---

<section class="hero">
  {bgImage && (
    <img
      class="hero-bg"
      src={`${bgImage}?w=2000&q=75&fm=webp&auto=format&fit=crop`}
      alt={bgAlt ?? ''}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  )}
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="wrap">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{headline}</h1>
    <p class="sub">{sub}</p>
    <div class="cta-row">
      <WhatsAppCTA
        context="global"
        lang={lang}
        label={t(lang, 'cta.book')}
        variant="primary"
        analytics={`whatsapp_hero_${lang}`}
      />
      <a href="#servicos" class="btn btn-ghost-dark">{t(lang, 'cta.services')}</a>
    </div>
  </div>
  <div class="hero-skyline">
    <SkylineDivider variant="hero" color="brass" />
  </div>
</section>

<style>
  .hero {
    background: var(--ink);
    color: var(--paper);
    padding: 6rem 1.25rem 2rem;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    opacity: 0.5;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(22,24,29,0.55) 0%, rgba(22,24,29,0.85) 70%, rgba(22,24,29,0.95) 100%);
  }
  .wrap {
    max-width: 68rem;
    margin: 0 auto;
    display: grid;
    gap: 1.25rem;
    position: relative;
  }
  .eyebrow {
    color: var(--brass);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.8rem;
  }
  h1 {
    color: var(--paper);
    max-width: 22ch;
  }
  .sub {
    color: var(--paper);
    opacity: 0.85;
    max-width: 60ch;
    font-size: 1.075rem;
    line-height: 1.65;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .hero-skyline {
    margin-top: 3rem;
  }
</style>

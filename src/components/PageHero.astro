---
export interface Props {
  eyebrow: string;
  headline: string;
  intro: string;
  bgImage?: string;
  bgAlt?: string;
}
const { eyebrow, headline, intro, bgImage, bgAlt } = Astro.props;
---

<section class="p-hero">
  {bgImage && (
    <img
      class="p-bg"
      src={`${bgImage}?w=2000&q=75&fm=webp&auto=format&fit=crop`}
      alt={bgAlt ?? ''}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  )}
  <div class="p-overlay" aria-hidden="true"></div>
  <div class="wrap">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{headline}</h1>
    <p class="intro">{intro}</p>
  </div>
</section>

<style>
  .p-hero {
    padding: 6rem 1.25rem 4rem;
    background: var(--ink);
    color: var(--paper);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .p-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    opacity: 0.45;
  }
  .p-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(22,24,29,0.6) 0%, rgba(22,24,29,0.9) 100%);
  }
  .wrap {
    max-width: 60rem;
    margin: 0 auto;
    display: grid;
    gap: 1.25rem;
    position: relative;
  }
  .eyebrow {
    color: var(--brass);
    font-family: var(--font-display);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.8rem;
  }
  h1 {
    color: var(--paper);
    max-width: 24ch;
  }
  .intro {
    color: var(--paper);
    opacity: 0.85;
    max-width: 60ch;
    font-size: 1.075rem;
    line-height: 1.65;
  }
</style>
